{
  "name": "AI Language Coach",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": false,
      "installGradle": false
    },
    "ghcr.io/devcontainers/features/dart:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/flutter:1": {
      "version": "3.22"
    },
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "nrwl.angular-console",
        "esbenp.prettier-vscode",
        "bierner.markdown-mermaid",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "dart.lineLength": 100,
        "dart.flutterSdkPath": "/usr/local/flutter",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "Dart-Code.dart-code",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  },
  "postCreateCommand": "cd frontend && flutter pub get",
  "mounts": [
    "source=${env:HOME}${env:USERPROFILE}/.pub-cache,target=/home/vscode/.pub-cache,type=bind"
  ],
  "remoteUser": "vscode"
}
