# AI Language Coach — Environment Configuration
# Copy this file to .env.development and fill in values.
# NEVER commit .env files to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Gateway ──────────────────────────────────────────────────────────────
AI_GATEWAY_URL=http://localhost:54321/functions/v1
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
PRIMARY_AI_PROVIDER=gemini
FALLBACK_AI_PROVIDER=openai

# ─── Voice (LiveKit) ────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ─── Payments (RevenueCat) ──────────────────────────────────────────────────
REVENUECAT_PUBLIC_KEY=your-revenuecat-public-key
REVENUECAT_SECRET_KEY=your-revenuecat-secret-key

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_ANDROID_API_KEY=your-firebase-android-key
FIREBASE_IOS_API_KEY=your-firebase-ios-key

# ─── App Configuration ──────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
API_TIMEOUT_SECONDS=15
